#!/usr/bin/env sh
# Block direct pushes to the production branch.
# Promote code to production via a pull request: staging -> main (merge on GitHub).
#
# Enable once per clone:  git config core.hooksPath .githooks

protected="main"

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/"$protected")
      echo "" >&2
      echo "  ✖  Direct push to '$protected' is blocked." >&2
      echo "     Production only accepts code via pull request: staging -> main (merge on GitHub)." >&2
      echo "" >&2
      echo "     On a different branch? Push that branch instead of main, e.g.:" >&2
      echo "        git push origin staging" >&2
      echo "" >&2
      exit 1
      ;;
  esac
done

exit 0
