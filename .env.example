# Public site URL — used for sitemap, OG tags
NEXT_PUBLIC_SITE_URL=https://webstudio.com

# Sanity CMS — get these at sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-17

# Sanity write token — needed for /api/seed-order
SANITY_API_WRITE_TOKEN=

# Resend — email notification for new orders (get this at resend.com)
RESEND_API_KEY=
# Email that receives order notifications
NOTIFICATION_EMAIL=
# Sending email (needs domain verification on Resend; leave blank to use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=

# Seed secret — set any secret string yourself
SEED_SECRET=

# Sanity webhook secret
SANITY_WEBHOOK_SECRET=

# Google Analytics 4 — get this at analytics.google.com (format G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Basic Auth password for /admin (middleware blocks access if wrong/empty)
ADMIN_PASSWORD=

# Vercel Edge Config — middleware reads domainMap to rewrite client domain → /preview/[slug]
# EDGE_CONFIG is the connection string (vercel.com → Edge Config → Connect)
EDGE_CONFIG=
# Used by /api/sync-domain to write domainMap to Edge Config
VERCEL_EDGE_CONFIG_ID=
VERCEL_API_TOKEN=
