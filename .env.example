# URL công khai của site — dùng cho sitemap, OG tags
NEXT_PUBLIC_SITE_URL=https://tiemwebnho.com

# Sanity CMS — lấy tại sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-17

# Sanity write token — cần cho /api/seed-order
SANITY_API_WRITE_TOKEN=

# Resend — email notification khi có đơn hàng mới (lấy tại resend.com)
RESEND_API_KEY=
# Email nhận thông báo đơn hàng
NOTIFICATION_EMAIL=
# Email gửi đi (cần verify domain tại Resend; để trống = dùng onboarding@resend.dev khi test)
RESEND_FROM_EMAIL=

# Seed secret — tự đặt bất kỳ chuỗi bí mật nào
SEED_SECRET=

# Sanity webhook secret
SANITY_WEBHOOK_SECRET=

# Google Analytics 4 — lấy tại analytics.google.com (dạng G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Mật khẩu Basic Auth cho /admin (middleware chặn nếu sai/trống)
ADMIN_PASSWORD=

# Vercel Edge Config — middleware đọc domainMap để rewrite domain khách → /preview/[slug]
# EDGE_CONFIG là connection string (vercel.com → Edge Config → Connect)
EDGE_CONFIG=
# Dùng cho /api/sync-domain ghi domainMap vào Edge Config
VERCEL_EDGE_CONFIG_ID=
VERCEL_API_TOKEN=
